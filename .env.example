# Server
PORT=8080
HOST=0.0.0.0
NODE_ENV=development

# Session signing (required in production — set via Boltable Secret)
SESSION_SECRET=change-me-in-production

# Auth — team leader sees all data
ROSALES_LEADER_PASSWORD=leader-dev-password

# Auth — per-agent passwords (JSON array)
# Each agent is matched by email when filtering /api/data
ROSALES_AGENTS_JSON=[{"id":"demo","name":"Demo Agent","email":"demo@bolt.eu","password":"agent-dev-password"}]

# Google Sheet cache (optional live read via service account)
ROSALES_SHEET_ID=1fs1VkfFESZfxcizC7oluBCbQJ6zjORZmSwLbr6Cr1og
GOOGLE_SERVICE_ACCOUNT_JSON=

# Path to local JSON cache (default: data/cache.json)
ROSALES_CACHE_PATH=

# Optional override: rep email → density|complex (see src/config.ts)
# ROSALES_REP_TEAMS_JSON={"demo@bolt.eu":"complex"}
